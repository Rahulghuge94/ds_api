# cookies from deepseek
DEEPSEEK_COOKIES= # ; saperated cookies from deepseek
# userToken from deepseek
DEEPSEEK_TOKEN= # update token from deepseek sites localstorage
# cookies from qwen
QWEN_COOKIES= # get cookies from qwen chat web
QWEN_TOKEN= # get token from qwen chat web
# cookies copied from an authenticated chatgpt.com browser session
CHATGPT_COOKIES=
# optional: use a bearer token directly instead of fetching one from cookies
CHATGPT_TOKEN=

# servr conf
PORT=8000
HOST=0.0.0.0

# wasm location
WASM_PATH="ds_api/sha3_wasm_bg.wasm"
REQUEST_LOG_FILE="logs/requests.log"

API_KEYS="asdfghjkl"# add comma separated keys as verified while user makes requesr
